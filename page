// ============================================================
// Page 50102 - Lens Order List
// ============================================================
page 50102 "Lens Order List"
{
    Caption = 'Заказы на линзы';
    PageType = List;
    SourceTable = "Lens Order";
    ApplicationArea = All;
    UsageCategory = Lists;
    CardPageId = "Lens Order Card";
    Editable = false;

    layout
    {
        area(Content)
        {
            repeater(Orders)
            {
                field("No."; Rec."No.") { ApplicationArea = All; }
                field("Customer Name"; Rec."Customer Name") { ApplicationArea = All; }
                field("Lens Description"; Rec."Lens Description") { ApplicationArea = All; }
                field("Optical Power (D)"; Rec."Optical Power (D)") { ApplicationArea = All; }
                field(Eye; Rec.Eye) { ApplicationArea = All; }
                field(Quantity; Rec.Quantity) { ApplicationArea = All; }
                field("Total Amount"; Rec."Total Amount") { ApplicationArea = All; }
                field("Order Date"; Rec."Order Date") { ApplicationArea = All; }
                field(Status; Rec.Status)
                {
                    ApplicationArea = All;
                    StyleExpr = StatusStyle;
                }
                field("Quality Check Passed"; Rec."Quality Check Passed") { ApplicationArea = All; }
            }
        }
    }

    var
        StatusStyle: Text;

    trigger OnAfterGetRecord()
    begin
        case Rec.Status of
            Rec.Status::New:
                StatusStyle := 'Ambiguous';
            Rec.Status::"In Production":
                StatusStyle := 'Favorable';
            Rec.Status::"Quality Check":
                StatusStyle := 'Attention';
            Rec.Status::Ready:
                StatusStyle := 'Favorable';
            Rec.Status::Shipped:
                StatusStyle := 'Strong';
            Rec.Status::Cancelled:
                StatusStyle := 'Unfavorable';
        end;
    end;

    actions
    {
        area(Processing)
        {
            action(StartProduction)
            {
                Caption = 'Запустить в производство';
                Image = Production;
                ApplicationArea = All;
                trigger OnAction()
                var
                    LensOrderMgt: Codeunit "Lens Order Mgt.";
                begin
                    LensOrderMgt.StartProduction(Rec);
                end;
            }
            action(MarkShipped)
            {
                Caption = 'Отгружен';
                Image = Ship;
                ApplicationArea = All;
                trigger OnAction()
                var
                    LensOrderMgt: Codeunit "Lens Order Mgt.";
                begin
                    LensOrderMgt.MarkAsShipped(Rec);
                end;
            }
        }
    }
}

// ============================================================
// Page 50103 - Lens Order Card (Карточка заказа)
// ============================================================
page 50103 "Lens Order Card"
{
    Caption = 'Заказ на линзы';
    PageType = Card;
    SourceTable = "Lens Order";
    ApplicationArea = All;
    UsageCategory = None;

    layout
    {
        area(Content)
        {
            group(General)
            {
                Caption = 'Основное';
                field("No."; Rec."No.") { ApplicationArea = All; }
                field("Customer No."; Rec."Customer No.") { ApplicationArea = All; }
                field("Customer Name"; Rec."Customer Name") { ApplicationArea = All; Editable = false; }
                field(Status; Rec.Status) { ApplicationArea = All; }
                field("Order Date"; Rec."Order Date") { ApplicationArea = All; }
                field("Requested Delivery Date"; Rec."Requested Delivery Date") { ApplicationArea = All; }
                field("Doctor Prescription No."; Rec."Doctor Prescription No.") { ApplicationArea = All; }
            }
            group(LensSpec)
            {
                Caption = 'Параметры линзы';
                field("Lens Product No."; Rec."Lens Product No.") { ApplicationArea = All; }
                field("Lens Description"; Rec."Lens Description") { ApplicationArea = All; Editable = false; }
                field("Optical Power (D)"; Rec."Optical Power (D)") { ApplicationArea = All; }
                field("Cylinder (D)"; Rec."Cylinder (D)") { ApplicationArea = All; }
                field("Axis (degrees)"; Rec."Axis (degrees)") { ApplicationArea = All; }
                field(Eye; Rec.Eye) { ApplicationArea = All; }
            }
            group(Pricing)
            {
                Caption = 'Стоимость';
                field(Quantity; Rec.Quantity) { ApplicationArea = All; }
                field("Unit Price"; Rec."Unit Price") { ApplicationArea = All; }
                field("Total Amount"; Rec."Total Amount") { ApplicationArea = All; Editable = false; Importance = Promoted; }
            }
            group(Production)
            {
                Caption = 'Производство';
                field("Quality Check Passed"; Rec."Quality Check Passed") { ApplicationArea = All; }
                field("Responsible Employee"; Rec."Responsible Employee") { ApplicationArea = All; }
                field("Production Notes"; Rec."Production Notes") { ApplicationArea = All; MultiLine = true; }
            }
        }
        area(FactBoxes)
        {
            systempart(Notes; Notes) { ApplicationArea = All; }
        }
    }

    actions
    {
        area(Promoted)
        {
            actionref(StartProd_Promoted; StartProduction) { }
            actionref(QC_Promoted; RunQualityCheck) { }
        }
        area(Processing)
        {
            action(StartProduction)
            {
                Caption = 'Запустить в производство';
                Image = Production;
                ApplicationArea = All;
                Promoted = true;
                PromotedCategory = Process;
                trigger OnAction()
                var
                    LensOrderMgt: Codeunit "Lens Order Mgt.";
                begin
                    LensOrderMgt.StartProduction(Rec);
                    CurrPage.Update();
                end;
            }
            action(RunQualityCheck)
            {
                Caption = 'Контроль качества';
                Image = Checklist;
                ApplicationArea = All;
                trigger OnAction()
                var
                    LensQCPage: Page "Lens Quality Check List";
                    LensQC: Record "Lens Quality Check";
                begin
                    LensQC.SetRange("Order No.", Rec."No.");
                    LensQCPage.SetTableView(LensQC);
                    LensQCPage.RunModal();
                    CurrPage.Update();
                end;
            }
        }
    }
}

