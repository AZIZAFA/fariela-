// ============================================================
// Page 50100 - Lens Product List (Список продуктов)
// ============================================================
page 50100 "Lens Product List"
{
    Caption = 'Каталог глазных линз';
    PageType = List;
    SourceTable = "Lens Product";
    ApplicationArea = All;
    UsageCategory = Lists;
    CardPageId = "Lens Product Card";
    Editable = false;

    layout
    {
        area(Content)
        {
            repeater(Products)
            {
                field("No."; Rec."No.") { ApplicationArea = All; }
                field(Description; Rec.Description) { ApplicationArea = All; }
                field("Lens Type"; Rec."Lens Type") { ApplicationArea = All; }
                field(Material; Rec.Material) { ApplicationArea = All; }
                field("Wear Duration"; Rec."Wear Duration") { ApplicationArea = All; }
                field("Diameter (mm)"; Rec."Diameter (mm)") { ApplicationArea = All; }
                field("Unit Price"; Rec."Unit Price") { ApplicationArea = All; }
                field(Status; Rec.Status) { ApplicationArea = All; }
            }
        }
    }

    actions
    {
        area(Processing)
        {
            action(NewOrder)
            {
                Caption = 'Создать заказ';
                Image = NewOrder;
                ApplicationArea = All;
                trigger OnAction()
                var
                    LensOrderCard: Page "Lens Order Card";
                    LensOrder: Record "Lens Order";
                begin
                    LensOrder.Init();
                    LensOrder."Lens Product No." := Rec."No.";
                    LensOrder."Lens Description" := Rec.Description;
                    LensOrder."Unit Price" := Rec."Unit Price";
                    LensOrderCard.SetRecord(LensOrder);
                    LensOrderCard.RunModal();
                end;
            }
        }
    }
}

