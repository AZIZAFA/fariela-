page 50104 "Lens Quality Check List"
{
    Caption = 'Контроль качества линз';
    PageType = List;
    SourceTable = "Lens Quality Check";
    ApplicationArea = All;
    UsageCategory = None;

    layout
    {
        area(Content)
        {
            repeater(QCEntries)
            {
                field("Entry No."; Rec."Entry No.") { ApplicationArea = All; }
                field("Order No."; Rec."Order No.") { ApplicationArea = All; }
                field("Check Date"; Rec."Check Date") { ApplicationArea = All; }
                field("Inspector Code"; Rec."Inspector Code") { ApplicationArea = All; }
                field("Optical Power Measured (D)"; Rec."Optical Power Measured (D)") { ApplicationArea = All; }
                field("Diameter Measured (mm)"; Rec."Diameter Measured (mm)") { ApplicationArea = All; }
                field("Surface Defects"; Rec."Surface Defects") { ApplicationArea = All; }
                field(Passed; Rec.Passed)
                {
                    ApplicationArea = All;
                    StyleExpr = QCStyle;
                }
                field(Comments; Rec.Comments) { ApplicationArea = All; }
            }
        }
    }

    var
        QCStyle: Text;

    trigger OnAfterGetRecord()
    begin
        if Rec.Passed then
            QCStyle := 'Favorable'
        else
            QCStyle := 'Unfavorable';
    end;
}
